NODE_ENV=production
PORT=3025
DATABASE_PATH=/app/data/sstv-iptv.sqlite
CACHE_DIR=/app/cache
SESSION_SECRET=replace-with-a-long-random-secret
FFMPEG_PATH=ffmpeg
FFMPEG_LOG_LEVEL=info
FFMPEG_USER_AGENT=VLC/3.0.20 LibVLC/3.0.20
FFMPEG_HLS_INPUT_MODE=direct
FFMPEG_RECONNECT_DELAY_MAX=5
FFMPEG_RW_TIMEOUT_SECONDS=15
FFMPEG_STALE_RESTART_SECONDS=30
FFMPEG_HLS_DVR_WINDOW_MINUTES=20
FFMPEG_HLS_STARTUP_BUFFER_SEGMENTS=4
FFMPEG_HLS_STARTUP_DISCARD_SEGMENTS=2
